# ──────────────── Local Development ────────────────
# Local PostgreSQL uses port 5433 (avoids conflicts with existing port 5432)
DATABASE_URL="postgresql://graquamarine_user:graquamarine_local_password@localhost:5433/graquamarine?schema=public"

# First admin account — used by npm run db:seed
ADMIN_NAME="Graquamarine Admin"
ADMIN_EMAIL="admin@graquamarine.local"
ADMIN_PASSWORD="replace-with-a-long-local-password"

# Session signing key — required for admin cookie security
ADMIN_SESSION_SECRET="replace-with-a-long-random-session-secret"

# Base URL for the site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ──────────────── Email (Resend) ────────────────
# Get your API key at https://resend.com/api-keys
RESEND_API_KEY=""
# Sender address. For local testing, Resend onboarding works:
#   Graquamarine <onboarding@resend.dev>
# For production, verify your domain first, then use:
#   Graquamarine <reservations@graquamarine.com>
EMAIL_FROM="Graquamarine <onboarding@resend.dev>"
# Admin inbox receiving reservation alerts
RESERVATION_EMAIL_TO=""
# Optional — separate inbox for contact form messages. Falls back to RESERVATION_EMAIL_TO.
CONTACT_EMAIL_TO=""

# ──────────────── Production (VPS) ────────────────
# After cloning to VPS, override these in production .env:
#
#   DATABASE_URL="postgresql://graquamarine_user:STRONG_PASSWORD@localhost:5432/graquamarine"
#   NEXT_PUBLIC_SITE_URL="https://graquamarine.com"
#   EMAIL_FROM="Graquamarine <reservations@graquamarine.com>"
#   ADMIN_SESSION_SECRET="openssl rand -base64 48"
#
# For full deployment instructions, see README.md > VPS Production Deployment.
